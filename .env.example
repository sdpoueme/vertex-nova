BOT_TOKEN=your-telegram-bot-token-here
ALLOWED_USER_IDS=your-telegram-user-id-here
SESSION_EXPIRY=daily
CLAUDE_TIMEOUT=300000
VAULT_PATH=your-obsidian-vault-path-here
# ANTHROPIC_API_KEY=             # Required for Docker deployment (native installs use Claude Code login)
# IMAGE_TEMP_DIR=/tmp/telegram-second-brain
# STT_PATH=whisper-cli             # Path to whisper.cpp binary
# STT_MODEL=                      # Path to GGML model file (enables voice support)
# AUDIO_TEMP_DIR=/tmp/synapse-audio
# TTS_PATH=piper              # Path to Piper TTS binary
# TTS_MODEL=                  # Path to Piper ONNX model (enables voice replies)
# TTS_VOICE_THRESHOLD=400     # Max chars for voice-only reply (longer gets voice + text)
# PROGRESS_MODE=off           # off | standard | detailed
# QUEUE_DEPTH=3               # max queued messages per user
# API_PORT=3000               # HTTP API port (enables the API when set)
# API_SECRET=                  # Bearer token for API auth (required if API_PORT is set)
# HOUSEKEEPING_ENABLED=true         # Enable/disable scheduled housekeeping
# HOUSEKEEPING_WEEKLY=sun:20:00     # Weekly review: day:HH:MM (local time)
# HOUSEKEEPING_MONTHLY=1:09:00      # Monthly review: day-of-month:HH:MM
# HOUSEKEEPING_YEARLY=1-1:10:00     # Yearly review: month-day:HH:MM
# LOG_LEVEL=info
# LOG_FILE=synapse.log
