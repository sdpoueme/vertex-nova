# ═══════════════════════════════════════════════════════
# Vertex Nova — Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# Lines starting with # are disabled. Remove # to enable.

HOME_NAME=Vertex Nova

# --- Channel Toggles (enable at least one) ---
TELEGRAM_ENABLED=true
WHATSAPP_ENABLED=false

# --- Telegram ---
# Get a bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_USER_IDS=your-user-id

# --- WhatsApp (requires Meta Business account) ---
# WHATSAPP_TOKEN=your-token
# WHATSAPP_PHONE_ID=your-phone-id
# WHATSAPP_VERIFY_TOKEN=vertex-nova-whatsapp
# WHATSAPP_WEBHOOK_PORT=3001
# WHATSAPP_ALLOWED_NUMBERS=15551234567

# --- Sonos (Official Cloud API) ---
# Register at developer.sonos.com, then run: node scripts/sonos-auth.js
# SONOS_CLIENT_ID=your-client-id
# SONOS_CLIENT_SECRET=your-client-secret
# SONOS_DEFAULT_ROOM=Living Room
# SONOS_DAY_ROOM=Living Room
# SONOS_NIGHT_ROOM=Basement
# SONOS_TTS_VOLUME=30

# --- Echo Devices (Alexa API) ---
# Echo devices speak directly via the Alexa API (no Voice Monkey needed)
# ECHO_DEVICES=device1,device2,device3
# ECHO_MORNING_DEVICE=your-kitchen-device
# ECHO_WORKDAY_DEVICE=your-office-device
# ECHO_EVENING_DEVICE=your-kitchen-device

# --- TTS (Piper — for Sonos voice output) ---
# PIPER_PATH=/path/to/piper
# TTS_MODEL=/path/to/en_US-amy-medium.onnx
# TTS_FR_MODEL=/path/to/fr_FR-siwis-medium.onnx
# TTS_SERVER_PORT=3004

# --- STT (whisper.cpp — for voice messages) ---
# STT_PATH=whisper-cli
# STT_MODEL=/path/to/ggml-medium.bin

# --- AI Models ---
# ANTHROPIC_API_KEY=your-claude-api-key
# CLAUDE_MODEL=claude-sonnet-4-6
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b

# --- Home Location (used for weather, news, proactive actions) ---
# HOME_LOCATION=Your City, Province
# HOME_COUNTRY=Your Country
# NEWS_LOCALE=fr-CA
# NEWS_COUNTRY=CA
# NEWS_EXTRA_TOPICS=Cameroun

# --- Movie Preferences (TMDB — free API key at themoviedb.org) ---
# TMDB_API_KEY=your-free-tmdb-api-key
# MOVIE_GENRES=action,comedy,drama,thriller,animation
# MOVIE_LANGUAGE=fr
# MOVIE_REGION=CA

# --- Alexa Smart Home API (device state monitoring) ---
# Extract from alexa.amazon.com browser cookies (DevTools → Application → Cookies)
# ALEXA_UBID_MAIN=your-ubid-main-cookie
# ALEXA_AT_MAIN=your-at-main-cookie

# --- Email Agent (inbox monitoring + reply drafting + sending) ---
# Uses Gmail App Password for reading (Atom feed) and sending (SMTP)
# Get an App Password: Google Account → Security → 2-Step Verification → App passwords
# EMAIL_MONITOR_ADDRESS=your-email@gmail.com
# EMAIL_MONITOR_PASSWORD=your-app-password
# EMAIL_POLL_INTERVAL=60000

# --- Presence Detection (who's home via WiFi) ---
# Format: Name1:mac1,Name2:mac2 (get MAC from arp -a or router admin)
# PRESENCE_DEVICES=Serge:6c:3a:ff:8a:06:ed,Stéphanie:aa:bb:cc:dd:ee:ff
# PRESENCE_POLL_SECONDS=30

# --- Core ---
SESSION_EXPIRY=daily
CLAUDE_TIMEOUT=300000
VAULT_PATH=vault
# DASHBOARD_PORT=3080
# USE_STRANDS=true
